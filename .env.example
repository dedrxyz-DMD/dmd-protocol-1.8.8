# DMD Protocol Deployment Environment Variables
# Copy this file to .env and fill in your values
# NEVER COMMIT .env - it contains secrets!

# Deployer private key (without 0x prefix)
# Get this from your wallet (MetaMask: Settings -> Security -> Reveal Private Key)
PRIVATE_KEY=your_private_key_here_without_0x

# Basescan API Key for contract verification
# Get from: https://basescan.org/myapikey
BASESCAN_API_KEY=your_basescan_api_key_here

# Optional: Custom RPC endpoints (use defaults if slow)
# BASE_SEPOLIA_RPC=https://sepolia.base.org
# BASE_MAINNET_RPC=https://mainnet.base.org

# Optional: Alternative RPCs (if public endpoints are congested)
# BASE_SEPOLIA_RPC=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
# BASE_MAINNET_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
